// AI IPO Assistant — data model
// Postgres (Docker locally, Supabase/Neon in production).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A registered user (simple email + password auth).
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  emailOptIn   Boolean       @default(true) // receive the daily reminder email
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]

  @@map("users")
}

/// Lifecycle of an IPO.
enum IpoStatus {
  UPCOMING
  LIVE
  CLOSED
  LISTED
}

/// AI conviction label for an IPO.
enum AiLabel {
  high_conviction
  good
  neutral
  avoid
}

/// Overall stock-market mood, which influences IPO listing prospects.
enum MarketSentiment {
  BULLISH
  NEUTRAL
  CAUTIOUS
  BEARISH
}

/// A single snapshot of broad market conditions (singleton row id "current").
/// Used to contextualise IPO rankings — a strong market lifts listing gains,
/// a weak/volatile one suppresses them.
model MarketSnapshot {
  id                  String          @id @default("current")
  sentiment           MarketSentiment @default(NEUTRAL)
  niftyChangePct      Float           @default(0) // recent Nifty 50 move %
  sensexChangePct     Float           @default(0) // recent Sensex move %
  indiaVix            Float           @default(0) // volatility index
  recentListingAvgPct Float           @default(0) // avg listing gain of recent IPOs
  note                String          @default("")
  updatedAt           DateTime        @updatedAt

  @@map("market_snapshot")
}

/// An IPO with market data and AI-generated ranking.
model Ipo {
  id        String    @id @default(cuid())
  name      String
  symbol    String    @unique // slug/ticker used as a stable key
  sector    String? // may be unknown from a live source
  exchange  String  @default("NSE") // e.g. "NSE", "BSE", "NSE SME"

  // Nullable: a live source may not have priced an upcoming IPO yet.
  priceBandLow  Int?
  priceBandHigh Int?
  lotSize       Int?
  issueSizeCr   Float? // total issue size in ₹ crore

  openDate    DateTime?
  closeDate   DateTime?
  listingDate DateTime?

  status IpoStatus @default(UPCOMING)

  // Market sentiment signals used for ranking.
  gmp               Int     @default(0) // grey market premium (₹)
  gmpPct            Float? // GMP as % of issue price (used when price band is unknown)
  subscriptionTimes Float   @default(0) // total subscription (x times)

  // Provenance.
  source       String? // "ipoguru-api" | "ipoguru-scrape" | "seed"
  lastSyncedAt DateTime?

  // Subscription breakdown (x times), once bidding is live.
  qibX    Float @default(0) // Qualified Institutional Buyers
  niiX    Float @default(0) // Non-Institutional Investors
  retailX Float @default(0) // Retail Individual Investors

  // Company & business.
  about String? // short business description

  // Financials (₹ crore) — latest and previous fiscal year.
  revenueCr       Float? // latest FY revenue
  revenuePrevCr   Float? // previous FY revenue
  patCr           Float? // profit after tax, latest FY
  patPrevCr       Float? // profit after tax, previous FY
  ebitdaMarginPct Float? // EBITDA margin %

  // Valuation & returns.
  peRatio      Float? // post-issue P/E
  industryPe   Float? // industry average P/E (for comparison)
  roePct       Float? // return on equity / net worth %
  rocePct      Float? // return on capital employed %
  debtToEquity Float? // debt-to-equity ratio
  marketCapCr  Float? // post-issue market cap (₹ crore)

  // Issue structure.
  freshIssueCr   Float? // fresh issue portion (₹ crore)
  ofsCr          Float? // offer-for-sale portion (₹ crore)
  promoterPrePct Float? // promoter holding before issue %
  promoterPostPct Float? // promoter holding after issue %
  registrar      String?

  // Qualitative analysis (Postgres scalar lists, default empty).
  strengths String[]
  risks     String[]
  objects   String[] // objects of the issue (use of proceeds)

  // Cached AI ranking output.
  aiScore    Float?
  aiLabel    AiLabel?
  aiReason   String?
  aiAnalysis String? // longer AI analyst note grounded in fundamentals
  aiRankedAt DateTime?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]

  @@index([status])
  @@map("ipos")
}

/// Tracks whether a user has applied to a given IPO.
model Application {
  id        String   @id @default(cuid())
  userId    String
  ipoId     String
  applied   Boolean  @default(true)
  appliedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipo  Ipo  @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@unique([userId, ipoId])
  @@index([userId])
  @@map("applications")
}
