# ─────────────────────────────────────────────────────────────
# AI IPO Assistant — environment variables
# Copy this file to `.env` and fill in the values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Postgres connection string.
# The value below works with the local Docker Postgres (npm run docker:up).
# In production, paste your Supabase / Neon connection string here
# (use the POOLED / "Transaction" string for serverless on Vercel).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_ipo?schema=public"

# ── Auth ──────────────────────────────────────────────────────
# Long random string used to sign JWT auth tokens (required, min 16 chars).
# Generate one with:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# ── AI ranking (Groq) ─────────────────────────────────────────
# Free LLM key from https://console.groq.com/keys
# OPTIONAL: leave blank to fall back to the deterministic heuristic ranker.
GROQ_API_KEY=""
# Model used for ranking. Default is a free, fast Llama 3.3 model.
GROQ_MODEL="llama-3.3-70b-versatile"

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Gmail address that sends the daily reminder email.
GMAIL_USER="your_email@gmail.com"
# Gmail APP PASSWORD (NOT your account password). Requires 2-Step Verification.
# Generate at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD="your_app_password_here"
# Display name shown as the email sender.
MAIL_FROM_NAME="AI IPO Assistant"

# ── Cron protection ───────────────────────────────────────────
# Random string sent as a Bearer token to protect the cron + rank routes
# (/api/rank and /api/cron/daily-reminder).
# Generate one with:  openssl rand -base64 32
CRON_SECRET="change-me-to-a-long-random-string"

# ── App ───────────────────────────────────────────────────────
# Public base URL. Use http://localhost:3000 locally, your domain in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
